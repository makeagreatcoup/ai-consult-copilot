# 咨询AI副驾 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# Anthropic API Key（必填）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Claude 模型选择（默认 claude-sonnet-4-20250514）
CLAUDE_MODEL=claude-sonnet-4-20250514

# Whisper 模型大小（tiny/base/small/medium）
WHISPER_MODEL=small

# 计算设备（cuda / cpu）
WHISPER_DEVICE=cuda

# 计算精度（float16 / int8）
WHISPER_COMPUTE_TYPE=int8
